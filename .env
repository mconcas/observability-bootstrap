# Opensearch source, currently on some staging version
OPENSEARCH_DOCKER_REPO=opensearchstaging

# OpenSearch configuration
OPENSEARCH_VERSION=3.6.0
OPENSEARCH_PASSWORD=MyStr0ng!Pass#2024

# OpenSearch-Dashboards configuration
OPENSEARCH_DASHBOARDS_VERSION=3.6.0

# Prometheus configuration
PROMETHEUS_VERSION=v3.10.0

# OTel Collector configuration
OTEL_COLLECTOR_CONTRIB_VERSION=0.148.0

# Data-prepper configuration
DATA_PREPPER_VERSION=2.14.0

# Fluent-bit configuration
FLUENTBIT_VERSION=4.2.3

# Rootless Docker: set to output of `docker info -f '{{.DockerRootDir}}'`
DOCKER_ROOT_DIR=${HOME}/.local/share/docker

# Network
NETWORK_NAME=observability-bootstrap-net